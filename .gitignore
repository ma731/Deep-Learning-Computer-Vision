# Python
__pycache__/
*.pyc
.venv/
venv/
.ipynb_checkpoints/

# Raw/full datasets are too large for git (download via scripts/build_dataset.py).
# A small curated sample lives in data/sample_images/ and IS committed.
data/raw/
data/dataset/
field_test/
*.h5
*.pt
*.keras
# ...but DO commit the trained models and a few sample images so the repo runs.
!models/*.keras
!data/sample_images/**
# active-learning review queue (runtime crops + log)
data/review_queue/
models/review_queue.jsonl
# ANN baseline is 164MB (>GitHub's 100MB limit); regenerate via scripts/train_compare_models.py
models/ann_baseline.keras
# ephemeral public tunnel URL written by scripts/go_live.ps1 at runtime
.public_url

# Logs
logs/
runs/
.tensorboard/

# OS / editor
.DS_Store
Thumbs.db
.vscode/

