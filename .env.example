# FreshGuard environment — copy this file to `.env` and fill in your key.
# The backend auto-loads `.env` at startup (no extra dependency).

# USDA Market News API key (free: https://mymarketnews.ams.usda.gov/).
# When set, the Market tab serves live US terminal-market produce prices
# instead of the calibrated reference table.
USDA_API_KEY=

# Optional: which USDA MARS report slug to pull (default 2852 = a terminal F&V report).
# USDA_REPORT=2852
